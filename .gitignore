```gitignore
# ==========================================================
# Velocity - .gitignore
# Modern C++ | Qt 6 | CMake
# ==========================================================

# ----------------------------------------------------------
# Build Directories
# ----------------------------------------------------------
build/
build-*/
cmake-build-*/
out/
bin/
lib/

# ----------------------------------------------------------
# CMake Generated Files
# ----------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
Testing/

# ----------------------------------------------------------
# Make / Ninja
# ----------------------------------------------------------
Makefile
*.ninja
.ninja_deps
.ninja_log

# ----------------------------------------------------------
# Visual Studio
# ----------------------------------------------------------
.vs/
*.VC.db
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# ----------------------------------------------------------
# Visual Studio Code
# ----------------------------------------------------------
.vscode/

# Uncomment if you want to share workspace settings
# !.vscode/settings.json
# !.vscode/extensions.json

# ----------------------------------------------------------
# CLion / JetBrains
# ----------------------------------------------------------
.idea/

# ----------------------------------------------------------
# Qt Creator
# ----------------------------------------------------------
*.pro.user
*.pro.user.*
*.qbs.user
*.autosave

# ----------------------------------------------------------
# Qt Generated Files
# ----------------------------------------------------------
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
*.qmlc
*.jsc

# ----------------------------------------------------------
# Object Files
# ----------------------------------------------------------
*.o
*.obj
*.lo
*.slo

# ----------------------------------------------------------
# Libraries
# ----------------------------------------------------------
*.a
*.lib
*.so
*.so.*
*.dylib

# ----------------------------------------------------------
# Executables
# ----------------------------------------------------------
*.exe
*.out
*.app
*.ipa

# ----------------------------------------------------------
# Debug Files
# ----------------------------------------------------------
*.dSYM/
*.pdb

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ----------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# Coverage Reports
# ----------------------------------------------------------
coverage/
*.gcda
*.gcno
*.gcov

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------
.cache/

# ----------------------------------------------------------
# Environment Files
# ----------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------
local_settings.json

# ----------------------------------------------------------
# Archives
# ----------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.7z
*.rar
```
